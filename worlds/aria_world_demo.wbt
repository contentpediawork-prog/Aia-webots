#VRML_SIM R2023b utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023b/projects/objects/floors/protos/RectangleArena.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023b/projects/objects/tables/protos/Table.proto"

WorldInfo {
  info [ "ARIA - Assistive Robot for Independent Ageing - CO7316 Webots simulation" ]
  basicTimeStep 16
}
Viewpoint {
  orientation -0.25 0.95 0.2 1.1
  position 1.9 -2.3 2.0
}
TexturedBackground {
}
TexturedBackgroundLight {
}

RectangleArena {
  floorSize 5 5
  floorTileSize 1 1
  wallHeight 0.3
}

Table {
  translation 1.3 1.3 0
  size 0.6 0.6 0.5
}

# Small object on the table for ARIA to retrieve (stands in for a medication box)
Solid {
  translation 1.3 1.3 0.52
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.9 0.2 0.2
        roughness 0.6
      }
      geometry Box {
        size 0.08 0.05 0.04
      }
    }
  ]
  name "target_object"
  boundingObject Box {
    size 0.08 0.05 0.04
  }
  physics Physics {
    density 400
  }
}

# ARIA robot: cylindrical base, telescoping torso, simple 2-DOF arm, gripper, pan-tilt head
Robot {
  translation 0 0 0.05
  rotation 0 0 1 0
  name "ARIA"
  controller "aria_demo"
  children [
    # --- base body (visual) ---
    Transform {
      children [
        Shape {
          appearance PBRAppearance { baseColor 0.85 0.85 0.9 roughness 0.5 }
          geometry Cylinder { height 0.15 radius 0.2 }
        }
      ]
    }
    # --- left wheel ---
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 1 0
        anchor -0.18 0 -0.02
      }
      device [
        RotationalMotor {
          name "left_wheel_motor"
          maxVelocity 10
        }
      ]
      endPoint Solid {
        translation -0.18 0 -0.02
        rotation 1 0 0 1.5708
        children [
          Shape {
            appearance PBRAppearance { baseColor 0.1 0.1 0.1 }
            geometry Cylinder { height 0.04 radius 0.07 }
          }
        ]
        name "left_wheel"
        boundingObject Cylinder { height 0.04 radius 0.07 }
        physics Physics { }
      }
    }
    # --- right wheel ---
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 1 0
        anchor 0.18 0 -0.02
      }
      device [
        RotationalMotor {
          name "right_wheel_motor"
          maxVelocity 10
        }
      ]
      endPoint Solid {
        translation 0.18 0 -0.02
        rotation 1 0 0 1.5708
        children [
          Shape {
            appearance PBRAppearance { baseColor 0.1 0.1 0.1 }
            geometry Cylinder { height 0.04 radius 0.07 }
          }
        ]
        name "right_wheel"
        boundingObject Cylinder { height 0.04 radius 0.07 }
        physics Physics { }
      }
    }
    # --- rear caster (unpowered support point) ---
    Transform {
      translation 0 -0.15 -0.08
      children [
        Shape {
          appearance PBRAppearance { baseColor 0.1 0.1 0.1 }
          geometry Sphere { radius 0.03 }
        }
      ]
    }
    # --- telescoping torso (slider joint) ---
    SliderJoint {
      jointParameters JointParameters {
        axis 0 0 1
        minStop 0.0
        maxStop 0.6
      }
      device [
        LinearMotor {
          name "torso_lift_motor"
          minPosition 0.0
          maxPosition 0.6
          maxVelocity 0.15
        }
      ]
      endPoint Solid {
        translation 0 0 0.6
        children [
          Shape {
            appearance PBRAppearance { baseColor 0.6 0.6 0.65 }
            geometry Box { size 0.1 0.1 0.5 }
          }
          # --- shoulder hinge / upper arm ---
          HingeJoint {
            jointParameters HingeJointParameters {
              axis 0 1 0
              anchor 0 0 0.25
            }
            device [
              RotationalMotor {
                name "shoulder_motor"
                minPosition -1.57
                maxPosition 1.57
                maxVelocity 1.0
              }
            ]
            endPoint Solid {
              translation 0 0 0.25
              children [
                Shape {
                  appearance PBRAppearance { baseColor 0.5 0.5 0.55 }
                  geometry Box { size 0.04 0.04 0.25 }
                }
                # --- elbow hinge / forearm + gripper base ---
                HingeJoint {
                  jointParameters HingeJointParameters {
                    axis 0 1 0
                    anchor 0 0 0.15
                  }
                  device [
                    RotationalMotor {
                      name "elbow_motor"
                      minPosition -1.57
                      maxPosition 1.57
                      maxVelocity 1.0
                    }
                  ]
                  endPoint Solid {
                    translation 0 0 0.15
                    children [
                      Shape {
                        appearance PBRAppearance { baseColor 0.4 0.4 0.45 }
                        geometry Box { size 0.03 0.03 0.15 }
                      }
                      # --- gripper finger 1 ---
                      SliderJoint {
                        jointParameters JointParameters {
                          axis 1 0 0
                          minStop 0.0
                          maxStop 0.03
                        }
                        device [
                          LinearMotor {
                            name "gripper_motor_1"
                            minPosition 0.0
                            maxPosition 0.03
                            maxVelocity 0.05
                          }
                        ]
                        endPoint Solid {
                          translation 0.02 0 0.1
                          children [
                            Shape {
                              appearance PBRAppearance { baseColor 0.2 0.2 0.2 }
                              geometry Box { size 0.01 0.02 0.05 }
                            }
                          ]
                          name "finger_1"
                          boundingObject Box { size 0.01 0.02 0.05 }
                          physics Physics { }
                        }
                      }
                      # --- gripper finger 2 ---
                      SliderJoint {
                        jointParameters JointParameters {
                          axis 1 0 0
                          minStop -0.03
                          maxStop 0.0
                        }
                        device [
                          LinearMotor {
                            name "gripper_motor_2"
                            minPosition -0.03
                            maxPosition 0.0
                            maxVelocity 0.05
                          }
                        ]
                        endPoint Solid {
                          translation -0.02 0 0.1
                          children [
                            Shape {
                              appearance PBRAppearance { baseColor 0.2 0.2 0.2 }
                              geometry Box { size 0.01 0.02 0.05 }
                            }
                          ]
                          name "finger_2"
                          boundingObject Box { size 0.01 0.02 0.05 }
                          physics Physics { }
                        }
                      }
                    ]
                    name "forearm"
                    boundingObject Box { size 0.03 0.03 0.15 }
                    physics Physics { }
                  }
                }
              ]
              name "upper_arm"
              boundingObject Box { size 0.04 0.04 0.25 }
              physics Physics { }
            }
          }
        ]
        name "torso"
        boundingObject Box { size 0.1 0.1 0.5 }
        physics Physics { }
      }
    }
    # --- pan-tilt sensor head with camera + lidar ---
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 0 1
        anchor 0 0 0.85
      }
      device [
        RotationalMotor {
          name "head_pan_motor"
          minPosition -1.57
          maxPosition 1.57
        }
      ]
      endPoint Solid {
        translation 0 0 0.85
        children [
          Shape {
            appearance PBRAppearance { baseColor 0.2 0.2 0.2 }
            geometry Box { size 0.08 0.08 0.08 }
          }
          Camera {
            translation 0 0.05 0
            name "aria_camera"
            width 320
            height 240
          }
          Lidar {
            translation 0 0 0.05
            name "aria_lidar"
            horizontalResolution 180
            fieldOfView 6.28
            numberOfLayers 1
            maxRange 5
          }
        ]
        name "head"
        boundingObject Box { size 0.08 0.08 0.08 }
        physics Physics { }
      }
    }
  ]
  boundingObject Cylinder { height 0.15 radius 0.2 }
  physics Physics {
    density -1
    mass 25
  }
}

# Supervisor robot used only to start/stop the video recording (see aria_recorder controller)
Robot {
  name "recorder"
  controller "aria_recorder"
  supervisor TRUE
  children []
}
